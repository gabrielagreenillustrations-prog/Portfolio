{
  "$description": "Gabi Portfolio design tokens. DTCG format — import into Figma with the 'Tokens Studio for Figma' plugin, then 'Create Variables'. Names map 1:1 to CSS custom properties: group.name -> --group-name. Fluid type sizes store the DESKTOP (clamp max) value; responsive min/vw is documented in DESIGN-SYSTEM.md.",
  "color": {
    "sand": {
      "100": { "$type": "color", "$value": "#f0ebe3" },
      "200": { "$type": "color", "$value": "#e8e2da" },
      "300": { "$type": "color", "$value": "#c8c2bb" }
    },
    "cream": { "$type": "color", "$value": "#f5f0ea" },
    "ink": {
      "900": { "$type": "color", "$value": "#111009" }
    },
    "green": {
      "500": { "$type": "color", "$value": "#22c55e" },
      "800": { "$type": "color", "$value": "#166634" }
    },
    "white": { "$type": "color", "$value": "#ffffff" },
    "espresso": {
      "900": { "$type": "color", "$value": "#201e0f", "$description": "primary CTA black — only black in the UI" }
    },
    "stone": {
      "400": { "$type": "color", "$value": "#aba592", "$description": "selected nav tab" },
      "500": { "$type": "color", "$value": "#969080", "$description": "pressed nav tab" }
    }
  },
  "semantic-color": {
    "bg": { "$type": "color", "$value": "{color.sand.200}" },
    "bg-alt": { "$type": "color", "$value": "{color.sand.100}" },
    "surface-dark": { "$type": "color", "$value": "{color.ink.900}" },
    "placeholder": { "$type": "color", "$value": "{color.sand.300}" },
    "glass": { "$type": "color", "$value": "rgba(232,226,218,0.85)" },
    "ink": { "$type": "color", "$value": "rgba(17,16,9,1)" },
    "ink-55": { "$type": "color", "$value": "rgba(17,16,9,0.55)" },
    "ink-15": { "$type": "color", "$value": "rgba(17,16,9,0.15)" },
    "ink-08": { "$type": "color", "$value": "rgba(17,16,9,0.08)" },
    "on-dark": { "$type": "color", "$value": "{color.cream}" },
    "on-dark-65": { "$type": "color", "$value": "rgba(245,240,234,0.65)" },
    "on-dark-42": { "$type": "color", "$value": "rgba(245,240,234,0.42)" },
    "on-dark-32": { "$type": "color", "$value": "rgba(245,240,234,0.32)" },
    "on-dark-15": { "$type": "color", "$value": "rgba(245,240,234,0.15)" },
    "on-dark-09": { "$type": "color", "$value": "rgba(245,240,234,0.09)" },
    "on-image": { "$type": "color", "$value": "rgba(255,255,255,0.75)" },
    "success-ink": { "$type": "color", "$value": "{color.green.800}" },
    "success-bg": { "$type": "color", "$value": "rgba(34,197,94,0.14)" },
    "success-bg-soft": { "$type": "color", "$value": "rgba(34,197,94,0.1)" },
    "success-border": { "$type": "color", "$value": "rgba(34,197,94,0.25)" },
    "primary": { "$type": "color", "$value": "{color.espresso.900}" },
    "primary-ink": { "$type": "color", "$value": "{color.cream}" },
    "secondary-border": { "$type": "color", "$value": "{semantic-color.ink-15}" },
    "secondary-ink": { "$type": "color", "$value": "{semantic-color.ink}" },
    "tertiary-ink": { "$type": "color", "$value": "{semantic-color.ink-55}" },
    "tab-ink": { "$type": "color", "$value": "{semantic-color.ink-55}" },
    "tab-hover-bg": { "$type": "color", "$value": "{semantic-color.ink-08}" },
    "tab-hover-ink": { "$type": "color", "$value": "{semantic-color.ink}" },
    "tab-active-bg": { "$type": "color", "$value": "{color.stone.400}" },
    "tab-active-ink": { "$type": "color", "$value": "{semantic-color.ink}" },
    "tab-pressed-bg": { "$type": "color", "$value": "{color.stone.500}" }
  },
  "effect": {
    "grain": {
      "$type": "other",
      "$value": "feTurbulence fractalNoise baseFrequency=0.5 black 25% density 100%",
      "$description": "Film grain kept within an element's shape (text/images/dark surfaces), never the page bg. In code: SVG <filter id='grain'> + var(--grain-filter). Header uses a gradient variant (strong top → fade down). Figma: apply as a Noise texture/effect on the same layers."
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0px" },
    "0-5": { "$type": "dimension", "$value": "2px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "1-5": { "$type": "dimension", "$value": "6px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "7": { "$type": "dimension", "$value": "28px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "14": { "$type": "dimension", "$value": "56px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" },
    "24": { "$type": "dimension", "$value": "96px" }
  },
  "radius": {
    "xs": { "$type": "dimension", "$value": "2px" },
    "sm": { "$type": "dimension", "$value": "12px" },
    "lg": { "$type": "dimension", "$value": "20px" },
    "pill": { "$type": "dimension", "$value": "100px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "font-family": {
    "sans": { "$type": "fontFamily", "$value": "Manrope", "$description": "Single primitive — all type roles derive from this" },
    "heading": { "$type": "fontFamily", "$value": "{font-family.sans}" },
    "body": { "$type": "fontFamily", "$value": "{font-family.sans}" }
  },
  "font-size": {
    "$description": "Floors: footnotes 12px · content never < 14px · body 16px.",
    "2xs": { "$type": "dimension", "$value": "12px" },
    "xs": { "$type": "dimension", "$value": "12px" },
    "sm": { "$type": "dimension", "$value": "14px" },
    "md": { "$type": "dimension", "$value": "14px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "xl": { "$type": "dimension", "$value": "16px" },
    "2xl": { "$type": "dimension", "$value": "18px" },
    "3xl": { "$type": "dimension", "$value": "24px" },
    "footnote": { "$type": "dimension", "$value": "12px" },
    "caption": { "$type": "dimension", "$value": "14px" },
    "body": { "$type": "dimension", "$value": "16px" },
    "subheader": { "$type": "dimension", "$value": "16px" },
    "h4": { "$type": "dimension", "$value": "32px", "$description": "fluid clamp(1.4rem,2.5vw,2rem); 32px = desktop max" },
    "h3": { "$type": "dimension", "$value": "35px", "$description": "fluid clamp(1.5rem,3vw,2.2rem); 35px = desktop max" },
    "h2": { "$type": "dimension", "$value": "45px", "$description": "fluid clamp(1.8rem,3.2vw,2.8rem); 45px = desktop max" },
    "h1-project": { "$type": "dimension", "$value": "72px", "$description": "fluid clamp(2.5rem,5vw,4.5rem); 72px = desktop max" },
    "h1": { "$type": "dimension", "$value": "72px", "$description": "fluid clamp(2.8rem,5.5vw,4.5rem); 72px = desktop max" },
    "display": { "$type": "dimension", "$value": "120px", "$description": "fluid clamp(2.8rem,7.5vw,7.5rem); 120px = desktop max — hero ticker" },
    "lead": { "$type": "dimension", "$value": "18px", "$description": "fluid clamp(1rem,1.5vw,1.15rem); 18px = desktop max" }
  },
  "font-weight": {
    "light": { "$type": "number", "$value": 300 },
    "regular": { "$type": "number", "$value": 400 },
    "medium": { "$type": "number", "$value": 500 },
    "semibold": { "$type": "number", "$value": 600 },
    "bold": { "$type": "number", "$value": 700 }
  },
  "line-height": {
    "none": { "$type": "number", "$value": 1 },
    "tight": { "$type": "number", "$value": 1.05 },
    "snug": { "$type": "number", "$value": 1.25 },
    "normal": { "$type": "number", "$value": 1.5 },
    "relaxed": { "$type": "number", "$value": 1.6 },
    "loose": { "$type": "number", "$value": 1.7 }
  },
  "letter-spacing": {
    "tighter": { "$type": "dimension", "$value": "-0.03em" },
    "tight": { "$type": "dimension", "$value": "-0.025em" },
    "tight-sm": { "$type": "dimension", "$value": "-0.02em" },
    "normal": { "$type": "dimension", "$value": "0em" },
    "wide": { "$type": "dimension", "$value": "0.06em" },
    "wider": { "$type": "dimension", "$value": "0.1em" },
    "widest": { "$type": "dimension", "$value": "0.12em" }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(17,16,9,0.05)", "offsetX": "0px", "offsetY": "1px", "blur": "4px", "spread": "0px" },
        { "color": "rgba(17,16,9,0.04)", "offsetX": "0px", "offsetY": "2px", "blur": "10px", "spread": "0px" }
      ]
    },
    "card-hover": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(17,16,9,0.13)", "offsetX": "0px", "offsetY": "8px", "blur": "36px", "spread": "0px" },
        { "color": "rgba(17,16,9,0.07)", "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "0px" }
      ]
    },
    "img": {
      "$type": "shadow",
      "$value": { "color": "rgba(17,16,9,0.09)", "offsetX": "0px", "offsetY": "4px", "blur": "24px", "spread": "0px" }
    }
  },
  "layout": {
    "container-max": { "$type": "dimension", "$value": "1320px" },
    "container-pad": { "$type": "dimension", "$value": "32px" }
  }
}
